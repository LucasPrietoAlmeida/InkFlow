{
    "version": 2,
    "routes": [
        {
        "handle": "filesystem"
        },
        {
        "src": "/(assets|static)/.*",
        "headers": {
            "cache-control": "public, max-age=31536000, immutable"
        }
        },
        {
        "src": "/.*",
        "dest": "/index.html"
        }
    ]
}